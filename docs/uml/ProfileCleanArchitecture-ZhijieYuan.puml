@startuml
!pragma layout smetana
title Profile and Paper Lookup - Clean Architecture Dependencies
skinparam shadowing false
skinparam componentStyle rectangle
left to right direction

package "Entities" {
  [User]
  [Education]
  [Publication]
}

package "Use Cases" {
  [Load Profile Contracts]
  [Update Profile Contracts]
  [Paper Lookup Contracts]
  [Profile Interactors]
  [Data Access Interfaces]
}

package "Interface Adapters" {
  [Controllers]
  [Presenters]
  [View Models]
}

package "Frameworks" {
  [Swing Views]
  [ServerRepository]
  [SemanticScholarGateway]
}

package "App" {
  [Composition Root]
}

[Profile Interactors] --> [User]
[Profile Interactors] --> [Education]
[Profile Interactors] --> [Publication]
[Profile Interactors] --> [Load Profile Contracts]
[Profile Interactors] --> [Update Profile Contracts]
[Profile Interactors] --> [Paper Lookup Contracts]
[Profile Interactors] --> [Data Access Interfaces]
[Controllers] --> [Load Profile Contracts]
[Controllers] --> [Update Profile Contracts]
[Controllers] --> [Paper Lookup Contracts]
[Presenters] --> [Load Profile Contracts]
[Presenters] --> [Update Profile Contracts]
[Presenters] --> [Paper Lookup Contracts]
[Presenters] --> [View Models]
[Swing Views] --> [Controllers]
[Swing Views] --> [View Models]
[ServerRepository] ..> [Data Access Interfaces] : implements
[SemanticScholarGateway] ..> [Data Access Interfaces] : implements
[Composition Root] --> [Swing Views]
[Composition Root] --> [Controllers]
[Composition Root] --> [Presenters]
[Composition Root] --> [Profile Interactors]
[Composition Root] --> [ServerRepository]
[Composition Root] --> [SemanticScholarGateway]

note bottom of [Data Access Interfaces]
All source-code dependencies point inward.
External implementations depend on use-case ports.
end note
@enduml
